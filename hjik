-- Capture billboard semua player
task.spawn(function()
    while task.wait() do
        if _G.StartAutoAnswer then
            for _, plr in ipairs(Players:GetPlayers()) do
                local head = plr.Character and plr.Character:FindFirstChild("Head")
                if head then
                    local billboard = head:FindFirstChild("TurnBillboard")
                    if billboard then
                        local textObj = billboard:FindFirstChild("Text")
                        if textObj then
                            billboardHistory[plr] = billboardHistory[plr] or {}
                            local history = billboardHistory[plr]
                            local lastText = history[#history]
                            if textObj.Text ~= lastText then
                                table.insert(history, textObj.Text)
                            end
                        end
                    end
                end
            end
        end
    end
end)

-- Auto add word ketika correct
PlayerCorrect.OnClientEvent:Connect(function(plr)
    local history = billboardHistory[plr]
    if history and #history > 0 then
        local correctText = history[#history]
        correctText = sanitizeWord(correctText)
        if correctText and not usedWords[correctText:lower()] then
            usedWords[correctText:lower()] = true
            print("Correct:", correctText)
            addWord(correctText)
        end
    end
end)

-- AUTO DELETE DETECTOR
task.spawn(function()
    while task.wait() do
        if _G.StartAutoAnswer then
            local tableState = LocalPlayer:GetAttribute("TableState")
            local isTurn = LocalPlayer:GetAttribute("IsTurn")
            if tableState == "Playing" and isTurn then
                local head = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Head")
                if head then
                    local billboard = head:FindFirstChild("TurnBillboard")
                    if billboard then
                        local textObj = billboard:FindFirstChild("Text")
                        if textObj then
                            local currentText = sanitizeWord(textObj.Text)
                            if lastBillboardText ~= currentText then
                                if lastSubmittedWord and currentText ~= lastSubmittedWord then
                                    print("Invalid word detected:", lastSubmittedWord)
                                    task.spawn(function()
                                        task.wait(0.4)
                                        safeDeleteWord(lastSubmittedWord)
                                    end)
                                    lastSubmittedWord = nil
                                end
                                lastBillboardText = currentText
                            end
                        end
                    end
                end
            end
        end
    end
end)

task.spawn(function()
    while task.wait() do
        if _G.StartAutoAnswer then
            if not _G.StartAutoAnswer then
                continue
            end
            while not LocalPlayer:GetAttribute("TableState") 
            or LocalPlayer:GetAttribute("IsTurn") == nil do
                task.wait(0.1)
            end
            local tableState = LocalPlayer:GetAttribute("TableState")
            local isTurn = LocalPlayer:GetAttribute("IsTurn")
            if tableState == "Playing" and isTurn then
                local WordServer = getWordServer()
                if WordServer and WordServer.Text ~= "" then
                    local currentLetter = WordServer.Text
                    local priorityWord = getPriorityWord(currentLetter)
                    if priorityWord then
                        task.wait(0.2)
                        autoTypeAndSubmit(priorityWord)
                    else
                        local candidates = getWords(currentLetter, "front")
                        if #candidates > 0 then
                            task.wait(0.2)
                            autoTypeAndSubmit(candidates[1])
                        end
                    end
                end
            end
            local ResultUI = LocalPlayer.PlayerGui:FindFirstChild("ResultUI")
            if ResultUI and ResultUI.Enabled then
                usedWords = {}
                print("Round ended, usedWords reset")
            end
        end
    end
end)

