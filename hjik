-- Fungsi tambah kata ke database
local function addWord(word)
    if not word then return end
    local response = request({
        Url = base_url,
        Method = "POST",
        Headers = {["Content-Type"] = "application/json"},
        Body = HttpService:JSONEncode({word = word:lower()})
    })

    if response.StatusCode == 201 then
        print("Saved:", word)
    else
        print("["..response.StatusCode.."]", response.Body)
    end
end

-- Sanitasi kata
local function sanitizeWord(word)
    if not word then return nil end
    word = word:lower()
    word = word:match("^%s*(.-)%s*$")
    word = word:gsub("[^a-z]", "")
    return word ~= "" and word or nil
end

-- Delete kata dari API
local function deleteWord(word)
    if not word then return end

    local response = request({
        Url = base_url .. "/delete",
        Method = "POST",
        Headers = {["Content-Type"] = "application/json"},
        Body = HttpService:JSONEncode({word = word:lower()})
    })

    if response.StatusCode == 200 then
        print("Deleted:", word)
    elseif response.StatusCode == 404 then
        print("Cant Delete, Not Found:", word)
    else
        print("["..response.StatusCode.."]:", response.Body)
    end
end

-- Cek apakah kata ada di API
local function isWordInAPI(word)
    local url = base_url .. "?filter=" .. word .. "&type=exact"
    local response = request({
        Url = url,
        Method = "GET"
    })
    if response.StatusCode == 200 then
        local data = HttpService:JSONDecode(response.Body)

        for _, w in pairs(data.words) do
            if w:lower() == word:lower() then
                return true
            end
        end
    end
    return false
end

-- Safe delete
local function safeDeleteWord(word)
    word = sanitizeWord(word)
    if word and isWordInAPI(word) then
        deleteWord(word)
    else
        print("Skip delete:", word)
    end
end

-- Ambil kata dari API
local function getWords(filter, type)
    local targetUrl = base_url .. "?filter=" .. filter .. "&type=" .. (type or "front")
    local response = request({
        Url = targetUrl,
        Method = "GET"
    })
    local results = {}
    if response.StatusCode == 200 then
        local data = HttpService:JSONDecode(response.Body)
        for _, w in pairs(data.words) do
            if not usedWords[w:lower()] then
                table.insert(results, w)
            end
        end
    else
        print("error getWords:", response.Body)
    end
    return results
end

-- PRIORITY WORD SEARCH
local function getPriorityWord(prefix)
    if not _G.PrioritasMode then
        return nil
    end
    for _, suffix in ipairs(PrioritySuffix) do
        local url = base_url .. "?filter=" .. prefix .. "&suffix=" .. suffix
        local response = request({
            Url = url,
            Method = "GET"
        })
        if response.StatusCode == 200 then
            local data = HttpService:JSONDecode(response.Body)
            for _, w in ipairs(data.words) do
                if not usedWords[w:lower()] then
                    print("Priority word:", w)
                    return w
                end
            end
        end
    end
    return nil
end

-- Auto type & submit
local function autoTypeAndSubmit(word)
    if not word then return end
    local typed = ""
    for i = 1, #word do
        typed = word:sub(1, i)
        BillboardUpdate:FireServer(typed)
        task.wait(0.2)
    end
    SubmitWord:FireServer(word)
    lastSubmittedWord = word
    usedWords[word:lower()] = true
    print("Submitted:", word)
end

-- Ambil WordServer UI
local function getWordServer()
    local gui = LocalPlayer.PlayerGui:FindFirstChild("MatchUI")
    if not gui then return nil end
    local bottomUI = gui:FindFirstChild("BottomUI")
    if not bottomUI then return nil end
    local topUI = bottomUI:FindFirstChild("TopUI")
    if not topUI then return nil end
    local frame = topUI:FindFirstChild("WordServerFrame")
    if not frame then return nil end
    return frame:FindFirstChild("WordServer")
end

